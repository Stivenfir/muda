PORT=3000
NODE_ENV=development
APP_NAME=ABC Mudanzas API
APP_VERSION=1.0.0

# Seguridad JWT (obligatorio)
JWT_SECRET=CAMBIAR_ESTE_SECRETO_EN_CADA_AMBIENTE
# Soporta ambos formatos (prioriza segundos)
JWT_EXPIRES_IN_SECONDS=28800
# JWT_EXPIRES_IN=8h

# Refresh tokens
AUTH_REFRESH_TTL_DAYS=7

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=abcmudanzas
