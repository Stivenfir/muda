# Backend
PORT=3000
NODE_ENV=development
APP_NAME=ABC Mudanzas API
APP_VERSION=1.0.0
JWT_SECRET=super_secret_dev_key
JWT_EXPIRES_IN=8h

# Base de datos (backend -> contenedor mysql)
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root123
DB_DATABASE=abcmudanzas

# XAMPP (si no usas contenedor mysql)
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=
# DB_DATABASE=abcmudanzas

# Docker compose (host -> contenedor mysql)
# Usar 3308 por defecto para evitar conflicto con XAMPP (3306)
MYSQL_HOST_PORT=3308
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=abcmudanzas
MYSQL_USER=appuser
MYSQL_PASSWORD=app123

# Frontend
VITE_API_URL=http://localhost:3000/api
